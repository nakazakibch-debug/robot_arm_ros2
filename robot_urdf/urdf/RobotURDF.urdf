<?xml version="1.0" encoding="utf-8"?>
<robot name="RobotURDF">

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.62991 0.83032 1.3221" rpy="0 0 0" />
      <mass value="0.20727" />
      <inertia ixx="0.00015865" ixy="4.7727E-11" ixz="-1.0581E-10" iyy="0.00028762" iyz="4.7831E-11" izz="0.00015865" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_urdf/meshes/base_link.STL" />
      </geometry>
      <material name="gray">
        <color rgba="0.8 0.8 0.8 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_urdf/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="lower_arm_link">
    <inertial>
      <origin xyz="-0.038375 0.054753 0.00017629" rpy="0 0 0" />
      <mass value="0.20366" />
      <inertia ixx="0.00043008" ixy="0.00036781" ixz="2.2125E-06" iyy="0.00042873" iyz="-2.3425E-06" izz="0.00080335" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Lower_arm_link.STL" />
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Lower_arm_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_lower_arm" type="revolute">
    <origin xyz="0.62991 -1.3221 0.84533" rpy="1.5708 0 -1.2076" />
    <parent link="base_link" />
    <child link="lower_arm_link" />
    <axis xyz="0 1 0" />
    <limit lower="-2.7784" upper="3.5048" effort="100.0" velocity="3.0" />
    <dynamics damping="0.1" friction="0.1" />
  </joint>

  <link name="upper_arm_link">
    <inertial>
      <origin xyz="-0.026532 0.035424 -0.019912" rpy="0 0 0" />
      <mass value="0.081962" />
      <inertia ixx="0.00010715" ixy="7.6283E-05" ixz="1.4705E-06" iyy="6.9068E-05" iyz="-1.9205E-06" izz="0.00017027" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Upper_arm_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Upper_arm_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_upper_arm" type="revolute">
    <origin xyz="-0.1 0.12 0" rpy="0 0 -0.69813" />
    <parent link="lower_arm_link" />
    <child link="upper_arm_link" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="3.4907" effort="100.0" velocity="3.0" />
  </joint>

  <link name="shoulder_drive_unit">
    <inertial>
      <origin xyz="4.8844E-05 0.0053084 0.0099363" rpy="0 0 0" />
      <mass value="0.038412" />
      <inertia ixx="1.7219E-05" ixy="5.7902E-10" ixz="1.8666E-08" iyy="1.7214E-05" iyz="1.7156E-07" izz="4.5367E-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Shoulder_Drive_unit.STL" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Shoulder_Drive_unit.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_shoulder_drive" type="revolute">
    <origin xyz="-0.074741 0.094413 0" rpy="1.5708 0 -0.17453" />
    <parent link="upper_arm_link" />
    <child link="shoulder_drive_unit" />
    <axis xyz="0 1 0" />
    <limit lower="0" upper="3.4907" effort="100.0" velocity="3.0" />
  </joint>

  <link name="rotary_yoke">
    <inertial>
      <origin xyz="-0.063121 -7.774E-09 -1.2065E-08" rpy="0 0 0" />
      <mass value="0.015728" />
      <inertia ixx="4.977E-06" ixy="2.2815E-13" ixz="-6.2587E-14" iyy="8.379E-06" iyz="-7.2624E-07" izz="6.9948E-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Rotary_Yoke.STL" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Rotary_Yoke.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_rotary_yoke" type="revolute">
    <origin xyz="0 0.005 0.010935" rpy="1.7732 1.5708 0" />
    <parent link="shoulder_drive_unit" />
    <child link="rotary_yoke" />
    <axis xyz="1 0 0" />
    <limit lower="-4.51" upper="1.7732" effort="100.0" velocity="3.0" />
  </joint>

  <link name="wrist_modul">
    <inertial>
      <origin xyz="0.0052933 1.6419E-09 1.2942E-09" rpy="0 0 0" />
      <mass value="0.034187" />
      <inertia ixx="3.7152E-06" ixy="5.7651E-14" ixz="4.1847E-14" iyy="8.9897E-06" iyz="-9.702E-13" izz="9.0315E-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Wrist_Modul.STL" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Wrist_Modul.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_wrist_modul" type="revolute">
    <origin xyz="-0.092065 0 0" rpy="-0.0099958 0.40463 1.5454" />
    <parent link="rotary_yoke" />
    <child link="wrist_modul" />
    <axis xyz="0 0 1" />
    <limit lower="-0.023336" upper="3.1183" effort="100.0" velocity="3.0" />
  </joint>

  <link name="gripper_actuator">
    <inertial>
      <origin xyz="7.4552E-09 -4.3137E-09 -0.0018911" rpy="0 0 0" />
      <mass value="0.016015" />
      <inertia ixx="1.7908E-06" ixy="1.6099E-09" ixz="-8.9889E-13" iyy="1.7334E-06" iyz="5.6896E-13" izz="1.869E-06" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Gripper_Actuator.STL" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Gripper_Actuator.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_gripper_actuator" type="revolute">
    <origin xyz="0.041707 0 0" rpy="-1.5708 0.77141 -1.5708" />
    <parent link="wrist_modul" />
    <child link="gripper_actuator" />
    <axis xyz="0 0 1" />
    <limit lower="-2.3702" upper="3.913" effort="100.0" velocity="3.0" />
  </joint>

  <link name="gripper">
    <inertial>
      <origin xyz="0.011924 0.011586 0.024243" rpy="0 0 0" />
      <mass value="0.0060192" />
      <inertia ixx="1.0653E-06" ixy="1.4493E-07" ixz="1.3848E-07" iyy="4.5269E-07" iyz="-4.325E-07" izz="7.8542E-07" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Gripper.STL" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_urdf/meshes/Gripper.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_gripper" type="revolute">
    <origin xyz="0.00030775 -0.010996 0.015293" rpy="-1.5708 -1.567 -1.5428" />
    <parent link="gripper_actuator" />
    <child link="gripper" />
    <axis xyz="0 0 1" />
    <limit lower="-1.3924" upper="0.0038261" effort="100.0" velocity="3.0" />
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="joint_lower_arm">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_upper_arm">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_shoulder_drive">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_rotary_yoke">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_wrist_modul">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_gripper_actuator">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_gripper">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_urdf)/config/controller.yaml</parameters>
    </plugin>
  </gazebo>

</robot>